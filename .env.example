# Copia este archivo a ".env" y completa tus valores reales.
# El servidor debe estar en offline-mode (cracked) para que el bot
# pueda conectarse solo con un username, sin cuenta Microsoft.

MC_HOST=localhost
# Dejar MC_PORT vacio si el host es una direccion tipo "*.aternos.me":
# esas direcciones usan un registro SRV que redirige a otro puerto interno,
# y al no forzar un puerto aqui, mineflayer lo resuelve solo (igual que el
# cliente oficial). Si tu servidor SI usa un puerto fijo normal, ponlo aqui.
MC_PORT=
MC_USERNAME=NPC_Bot
# Version del servidor, ej. 1.21.1. Dejar vacio para que mineflayer la detecte sola.
MC_VERSION=

# Cada cuanto (ms) el bot hace un pequeño movimiento/mirada para evitar el kick por AFK.
ANTI_AFK_INTERVAL_MS=30000

# Reconexion automatica si se cae la conexion o lo desconectan.
RECONNECT_DELAY_MS=10000
RECONNECT_MAX_DELAY_MS=300000

# Panel web en tiempo real (http://localhost:PANEL_PORT) con quien esta
# conectado ahora mismo, usando la vision del propio bot como jugador real.
PANEL_ENABLED=true
PANEL_PORT=3000
