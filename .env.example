# Copia este archivo a ".env" y completa tus valores reales.
# El servidor debe estar en offline-mode (cracked) para que el bot
# pueda conectarse solo con un username, sin cuenta Microsoft.

MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=NPC_Bot
# Version del servidor, ej. 1.21.1. Dejar vacio para que mineflayer la detecte sola.
MC_VERSION=

# Cada cuanto (ms) el bot hace un pequeño movimiento/mirada para evitar el kick por AFK.
ANTI_AFK_INTERVAL_MS=30000

# Reconexion automatica si se cae la conexion o lo desconectan.
RECONNECT_DELAY_MS=10000
RECONNECT_MAX_DELAY_MS=300000
